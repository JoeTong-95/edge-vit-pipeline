#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
cd "${ROOT}"

# Build extra --device flags for any /dev/video* nodes present on the host so
# live-camera modes work without editing this script.
VIDEO_DEVICES=()
for dev in /dev/video*; do
    [[ -e "$dev" ]] && VIDEO_DEVICES+=(--device "$dev")
done

docker run -it \
    --runtime=nvidia \
    --ipc=host \
    --ulimit memlock=-1 \
    --ulimit stack=67108864 \
    "${VIDEO_DEVICES[@]+"${VIDEO_DEVICES[@]}"}" \
    -v "${ROOT}":/app \
    vision-jetson:latest bash
