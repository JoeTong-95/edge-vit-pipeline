chat-history/
.codex

# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
*.pkl
*.pickle

# Model weights and checkpoints
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.engine
*.bin
*.gguf

# Local hydrated/model artifact directories
src/vlm-layer/Qwen3.5-0.8B-local-hydrated/
src/vlm-layer/SmolVLM-256M-Instruct/
src/vlm-layer/grace_integration/checkpoint/
_archive/experimental-models/
