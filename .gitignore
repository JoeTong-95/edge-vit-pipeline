chat-history/

# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
*.pkl
*.pickle

# Model weights and checkpoints
#*.pt
#*.pth
#*.ckpt
*.onnx
*.engine
*.bin

# ---------------------------------------------------------------------------
# Local run outputs (keep these out of git)
# ---------------------------------------------------------------------------
data/pipeline_output.*
data/*spill*.jsonl
data/*queue*.jsonl
data/*.jsonl

# Plots / benchmark artifacts that are regenerated locally
src/vlm-layer/benchmark/*.png

# ---------------------------------------------------------------------------
# Data videos SHOULD be tracked / synced
# ---------------------------------------------------------------------------
!data/*.mp4

# Local scheduled captures can be very large; keep them on-device unless
# explicitly curated for version control.
data/captures/

# Keep the curated conversion asset in MISC even though generic ONNX files are ignored.
!MISC/*.onnx

# ---------------------------------------------------------------------------
# TRT calibration artifacts (generated locally, large)
# ---------------------------------------------------------------------------
data/calib_frames/
data/calib_frames.cache
data/*.calib_cache
*.calib_cache

# Ultralytics model cache
*.cache
yolov8n.pt
